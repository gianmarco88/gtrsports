<script>
// ---- TODOS OS IDs editáveis ----
const ALL_FIELDS = [
  ['a-home-subtitle','home-subtitle'],['a-home-desc','home-desc'],
  ['a-about-title','about-title'],['a-about-text','about-text'],
  ['a-val1-title','val1-title'],['a-val1-text','val1-text'],
  ['a-val2-title','val2-title'],['a-val2-text','val2-text'],
  ['a-val3-title','val3-title'],['a-val3-text','val3-text'],
  ['a-rl-subtitle','rl-subtitle'],
  ['a-rl-about-title','rl-about-title'],['a-rl-about-text','rl-about-text'],
  ['a-rl-stat1','rl-stat1'],['a-rl-stat2','rl-stat2'],['a-rl-stat3','rl-stat3'],['a-rl-stat4','rl-stat4'],
  ['a-rl-p1-title','rl-p1-title'],['a-rl-p1-text','rl-p1-text'],
  ['a-rl-p2-title','rl-p2-title'],['a-rl-p2-text','rl-p2-text'],
  ['a-rl-p3-title','rl-p3-title'],['a-rl-p3-text','rl-p3-text'],
  ['a-pt-subtitle','pt-subtitle'],
  ['a-pt-about-title','pt-about-title'],['a-pt-about-text','pt-about-text'],
  ['a-pt-stat1','pt-stat1'],['a-pt-stat2','pt-stat2'],['a-pt-stat3','pt-stat3'],['a-pt-stat4','pt-stat4'],
  ['a-br-subtitle','br-subtitle'],
  ['a-br-about-title','br-about-title'],['a-br-about-text','br-about-text'],
  ['a-br-stat1','br-stat1'],['a-br-stat2','br-stat2'],['a-br-stat3','br-stat3'],['a-br-stat4','br-stat4'],
  ['a-br-community-title','br-community-title'],
  ['a-br-h1-title','br-h1-title'],['a-br-h1-text','br-h1-text'],
  ['a-br-h2-title','br-h2-title'],['a-br-h2-text','br-h2-text'],
  ['a-br-h3-title','br-h3-title'],['a-br-h3-text','br-h3-text'],
  ['a-stat-members','stat-members'],['a-stat-players','stat-players'],
  ['a-stat-tournaments','stat-tournaments'],['a-stat-wins','stat-wins'],
];

// ---- STATE ----
const state = {
 matches: { pt: [{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'w'},{wl:'l'},{wl:'l'}], br: [] },
  socials: {
    discord: 'https://discord.gg/d4KgNPx6NZ',
    tiktok: 'https://www.tiktok.com/@rl.spaceee'
  }
};

// ---- SHARED STORAGE HELPERS ----
async function sharedGet(key) {
  try { const r = await window.storage.get(key, true); return r ? r.value : null; } catch(e) { return null; }
}
async function sharedSet(key, value) {
  try { await window.storage.set(key, value, true); } catch(e) {}
}

// ---- CARREGAR DO STORAGE PARTILHADO ----
async function loadFromStorage() {
  for (const [, pageId] of ALL_FIELDS) {
    const saved = await sharedGet('gtr_' + pageId);
    const el = document.getElementById(pageId);
    if (saved && el) el.textContent = saved;
  }
  for (const team of ['rl','pt','br']) {
    const saved = await sharedGet('gtr_matches_' + team);
    if (saved) state.matches[team] = JSON.parse(saved);
  }
  const disc = await sharedGet('gtr_social_discord');
  const tik = await sharedGet('gtr_social_tiktok');
  state.socials.discord = disc || 'https://discord.gg/d4KgNPx6NZ';
  state.socials.tiktok = tik || 'https://www.tiktok.com/@rl.spaceee';
  renderMatches();
}

// ---- CURSOR ----
const cursor = document.getElementById('cursor');
const ring = document.getElementById('cursor-ring');
document.addEventListener('mousemove', e => {
  cursor.style.left = e.clientX - 6 + 'px';
  cursor.style.top = e.clientY - 6 + 'px';
  ring.style.left = e.clientX - 18 + 'px';
  ring.style.top = e.clientY - 18 + 'px';
});
document.addEventListener('mousedown', () => cursor.style.transform = 'scale(1.8)');
document.addEventListener('mouseup', () => cursor.style.transform = 'scale(1)');

function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.getElementById('nav-' + id)?.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
  renderMatches();
}

const observer = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// ---- RENDER MATCHES ----
function renderMatches() {
  ['rl','pt','br'].forEach(team => {
    const container = document.getElementById(team + '-matches-section');
    if (!container) return;
    const matches = state.matches[team];
    const wins = matches.filter(m => m.wl === 'w').length;
    const losses = matches.filter(m => m.wl === 'l').length;
    const total = wins + losses;
    const ratio = total > 0 ? Math.round((wins / total) * 100) : 0;
    const lossRatio = total > 0 ? Math.round((losses / total) * 100) : 0;
    container.innerHTML = `
      <div class="winloss-board">
        <div class="wl-box wins"><div class="wl-number">${wins}</div><div class="wl-label">Vitórias</div><div class="wl-bar"><div class="wl-bar-fill" style="width:${ratio}%"></div></div></div>
        <div class="wl-box losses"><div class="wl-number">${losses}</div><div class="wl-label">Derrotas</div><div class="wl-bar"><div class="wl-bar-fill" style="width:${lossRatio}%;background:linear-gradient(90deg,var(--red),var(--red-dark))"></div></div></div>
        <div class="wl-box ratio"><div class="wl-number">${ratio}%</div><div class="wl-label">Win Rate</div><div class="wl-bar"><div class="wl-bar-fill" style="width:${ratio}%;background:linear-gradient(90deg,#f59e0b,#d97706)"></div></div></div>
      </div>
      ${matches.length > 0 ? `<div class="matches-list">${matches.map(m => `
        <div class="match-row">
          <div class="match-badge ${m.wl}">${m.wl === 'w' ? 'W' : 'L'}</div>
          <div class="match-label">${m.wl === 'w' ? 'Vitória' : 'Derrota'}</div>
        </div>`).join('')}</div>`
      : '<p style="color:var(--grey);font-size:0.9rem;margin-top:12px;">Sem partidas registadas.</p>'}
    `;
  });
}

function renderAdminMatches() {
  ['rl','pt','br'].forEach(team => {
    const list = document.getElementById('a-' + team + '-matches');
    if (!list) return;
    const matches = state.matches[team];
    list.innerHTML = matches.length > 0 ? matches.map((m, i) => `
      <div class="player-item">
        <span class="role-tag" style="background:${m.wl==='w'?'rgba(34,197,94,0.15)':'rgba(229,9,20,0.15)'};color:${m.wl==='w'?'#22c55e':'var(--red)'};border:1px solid ${m.wl==='w'?'rgba(34,197,94,0.3)':'rgba(229,9,20,0.3)'}">${m.wl==='w'?'W':'L'}</span>
        <span>${m.wl === 'w' ? 'Vitória' : 'Derrota'}</span>
        <button class="del-btn" onclick="removeMatch('${team}',${i})">✕</button>
      </div>`).join('') : '<p style="color:var(--grey);font-size:0.9rem;">Sem partidas.</p>';
  });
}

function selectWL(team, val, btn) {
  document.getElementById(team + '-wl-group').querySelectorAll('.wl-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  document.getElementById(team + '-add-wl').value = val;
}

async function addMatch(team) {
  const wl = document.getElementById(team + '-add-wl').value;
  if (!wl) return;
  state.matches[team].push({ wl });
  await sharedSet('gtr_matches_' + team, JSON.stringify(state.matches[team]));
  document.getElementById(team + '-wl-group').querySelectorAll('.wl-btn').forEach(b => b.classList.remove('selected'));
  document.getElementById(team + '-add-wl').value = '';
  renderAdminMatches();
  renderMatches();
  showSaved();
}

async function removeMatch(team, index) {
  state.matches[team].splice(index, 1);
  await sharedSet('gtr_matches_' + team, JSON.stringify(state.matches[team]));
  renderAdminMatches();
  renderMatches();
  showSaved();
}

// ---- SOCIAIS ----
function openLink(type) {
  const url = state.socials[type];
  if (url) window.open(url, '_blank');
}

async function saveSocials() {
  const discord = document.getElementById('a-discord-url').value.trim();
  const tiktok = document.getElementById('a-tiktok-url').value.trim();
  if (discord) { state.socials.discord = discord; await sharedSet('gtr_social_discord', discord); }
  if (tiktok) { state.socials.tiktok = tiktok; await sharedSet('gtr_social_tiktok', tiktok); }
  showSaved();
}

// ---- ADMIN ----
function openAdmin() {
  document.getElementById('admin-overlay').classList.add('open');
  document.getElementById('admin-login').style.display = 'block';
  document.getElementById('admin-panel').style.display = 'none';
  document.getElementById('login-user').value = '';
  document.getElementById('login-pass').value = '';
  document.getElementById('login-error').style.display = 'none';
}

function closeAdmin() {
  document.getElementById('admin-overlay').classList.remove('open');
}

document.getElementById('admin-overlay').addEventListener('click', function(e) {
  if (e.target === this) closeAdmin();
});

function doLogin() {
  const u = document.getElementById('login-user').value;
  const p = document.getElementById('login-pass').value;
  if (u === 'admin' && p === 'gtr2026') {
    document.getElementById('admin-login').style.display = 'none';
    document.getElementById('admin-panel').style.display = 'block';
    loadAdminFields();
    renderAdminMatches();
  } else {
    document.getElementById('login-error').style.display = 'block';
  }
}

function switchTab(id, btn) {
  document.querySelectorAll('.admin-section').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.admin-tab').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}

function loadAdminFields() {
  ALL_FIELDS.forEach(([adminId, pageId]) => {
    const admin = document.getElementById(adminId);
    const page = document.getElementById(pageId);
    if (admin && page) admin.value = page.textContent;
  });
  // Sociais
  document.getElementById('a-discord-url').value = state.socials.discord || '';
  document.getElementById('a-tiktok-url').value = state.socials.tiktok || '';
}

// ---- SYNC + GUARDAR NO STORAGE PARTILHADO ----
async function syncAndSave(pairs) {
  for (const [adminId, pageId] of pairs) {
    const admin = document.getElementById(adminId);
    const page = document.getElementById(pageId);
    if (admin && page && admin.value.trim() !== '') {
      page.textContent = admin.value.trim();
      await sharedSet('gtr_' + pageId, admin.value.trim());
    }
  }
}

