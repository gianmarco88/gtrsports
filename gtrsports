<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GTR Sports — Esports Organization</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Bebas+Neue&family=Exo+2:wght@300;400;600;800&display=swap" rel="stylesheet">
<style>
  :root {
    --red: #e50914;
    --red-dark: #b0070f;
    --red-glow: rgba(229,9,20,0.4);
    --black: #0a0a0a;
    --dark: #111111;
    --dark2: #1a1a1a;
    --dark3: #222222;
    --white: #ffffff;
    --grey: #888888;
    --light-grey: #cccccc;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { font-family: 'Exo 2', sans-serif; background: var(--black); color: var(--white); overflow-x: hidden; cursor: none; }

  #cursor { width: 12px; height: 12px; background: var(--red); border-radius: 50%; position: fixed; pointer-events: none; z-index: 99999; transition: transform 0.1s; }
  #cursor-ring { width: 36px; height: 36px; border: 1.5px solid var(--red); border-radius: 50%; position: fixed; pointer-events: none; z-index: 99998; transition: transform 0.15s, opacity 0.3s; opacity: 0.5; }

  body::before { content: ''; position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E"); pointer-events: none; z-index: 9999; opacity: 0.3; }

  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: rgba(10,10,10,0.92); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(229,9,20,0.2); padding: 0 5%; display: flex; align-items: center; justify-content: space-between; height: 70px; }
  .logo { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 4px; color: var(--white); text-decoration: none; display: flex; align-items: center; gap: 10px; }
  .logo span { color: var(--red); }
  .logo-icon { width: 36px; height: 36px; background: var(--red); clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); display: flex; align-items: center; justify-content: center; font-size: 1.1rem; font-weight: 900; color: white; }
  .nav-links { display: flex; gap: 40px; list-style: none; align-items: center; }
  .nav-links a { text-decoration: none; color: var(--light-grey); font-family: 'Rajdhani', sans-serif; font-size: 1rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; transition: color 0.3s; position: relative; }
  .nav-links a .flag { text-transform: none; font-style: normal; letter-spacing: 0; }
  .nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: var(--red); transition: width 0.3s; }
  .nav-links a:hover { color: var(--white); }
  .nav-links a:hover::after { width: 100%; }
  .nav-links a.active { color: var(--red); }
  .nav-links a.active::after { width: 100%; }
  .nav-admin-btn { background: transparent; border: 1px solid rgba(229,9,20,0.3); color: var(--grey); padding: 6px 16px; font-family: 'Rajdhani', sans-serif; font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; cursor: pointer; transition: all 0.3s; border-radius: 2px; }
  .nav-admin-btn:hover { border-color: var(--red); color: var(--red); }

  .page { display: none; min-height: 100vh; }
  .page.active { display: block; }

  .hero { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; overflow: hidden; padding-top: 70px; }
  .hero-bg { position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(229,9,20,0.12) 0%, transparent 70%), linear-gradient(180deg, #0a0a0a 0%, #111 100%); }
  .hero-grid { position: absolute; inset: 0; background-image: linear-gradient(rgba(229,9,20,0.06) 1px, transparent 1px), linear-gradient(90deg, rgba(229,9,20,0.06) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 0%, transparent 100%); }
  .hero-scanlines { position: absolute; inset: 0; background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.15) 2px, rgba(0,0,0,0.15) 4px); pointer-events: none; }
  .hero-content { position: relative; z-index: 2; text-align: center; padding: 0 20px; }
  .hero-tag { display: inline-block; font-family: 'Rajdhani', sans-serif; font-size: 0.85rem; letter-spacing: 5px; color: var(--red); text-transform: uppercase; margin-bottom: 24px; opacity: 0; animation: fadeUp 0.8s 0.2s forwards; }
  .hero-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(5rem, 15vw, 12rem); line-height: 0.9; letter-spacing: 8px; opacity: 0; animation: fadeUp 0.8s 0.4s forwards; color: var(--white); }
  .hero-title .red { color: var(--red); }
  .hero-subtitle { font-size: clamp(1rem, 2.5vw, 1.4rem); color: var(--grey); font-weight: 300; letter-spacing: 3px; text-transform: uppercase; margin-top: 20px; opacity: 0; animation: fadeUp 0.8s 0.6s forwards; max-width: 600px; margin-left: auto; margin-right: auto; }
  .hero-divider { width: 120px; height: 2px; background: linear-gradient(90deg, transparent, var(--red), transparent); margin: 32px auto; opacity: 0; animation: fadeUp 0.8s 0.7s forwards; }
  .hero-desc { font-size: 1rem; color: var(--light-grey); max-width: 650px; margin: 0 auto 48px; line-height: 1.8; opacity: 0; animation: fadeUp 0.8s 0.9s forwards; }
  .hero-btns { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; opacity: 0; animation: fadeUp 0.8s 1.1s forwards; }

  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 14px 36px; font-family: 'Rajdhani', sans-serif; font-size: 1rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; border: none; cursor: pointer; text-decoration: none; transition: all 0.3s; position: relative; overflow: hidden; }
  .btn::before { content: ''; position: absolute; inset: 0; background: rgba(255,255,255,0.1); transform: translateX(-100%); transition: transform 0.3s; }
  .btn:hover::before { transform: translateX(0); }
  .btn-primary { background: var(--red); color: var(--white); clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px)); }
  .btn-primary:hover { background: var(--red-dark); box-shadow: 0 0 30px var(--red-glow); transform: translateY(-2px); }
  .btn-outline { background: transparent; color: var(--white); border: 1px solid rgba(255,255,255,0.3); clip-path: polygon(0 0, calc(100% - 12px) 0, 100% 12px, 100% 100%, 12px 100%, 0 calc(100% - 12px)); }
  .btn-outline:hover { border-color: var(--red); color: var(--red); box-shadow: 0 0 20px rgba(229,9,20,0.2); transform: translateY(-2px); }

  section { padding: 100px 5%; }
  .section-tag { font-family: 'Rajdhani', sans-serif; font-size: 0.8rem; letter-spacing: 5px; color: var(--red); text-transform: uppercase; margin-bottom: 12px; display: block; }
  .section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 6vw, 5rem); letter-spacing: 4px; line-height: 1; margin-bottom: 20px; }
  .section-desc { color: var(--grey); max-width: 600px; line-height: 1.8; font-size: 1rem; }

  .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 60px; }
  .card { background: var(--dark2); border: 1px solid rgba(255,255,255,0.06); padding: 40px; position: relative; overflow: hidden; transition: all 0.4s; cursor: pointer; }
  .card::before { content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 3px; background: var(--red); transform: scaleX(0); transition: transform 0.4s; }
  .card:hover { border-color: rgba(229,9,20,0.3); transform: translateY(-6px); box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
  .card:hover::before { transform: scaleX(1); }
  .card-icon { width: 56px; height: 56px; background: rgba(229,9,20,0.1); border: 1px solid rgba(229,9,20,0.3); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 24px; clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px)); }
  .card h3 { font-family: 'Rajdhani', sans-serif; font-size: 1.3rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; }
  .card p { color: var(--grey); line-height: 1.7; font-size: 0.9rem; }

  .stats-bar { background: var(--dark2); border-top: 1px solid rgba(229,9,20,0.2); border-bottom: 1px solid rgba(229,9,20,0.2); padding: 60px 5%; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 40px; text-align: center; }
  .stat-number { font-family: 'Bebas Neue', sans-serif; font-size: 4rem; color: var(--red); line-height: 1; }
  .stat-label { font-family: 'Rajdhani', sans-serif; letter-spacing: 3px; font-size: 0.8rem; text-transform: uppercase; color: var(--grey); margin-top: 8px; }

  .team-header { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; margin-bottom: 80px; }
  .team-visual { position: relative; height: 400px; background: var(--dark2); border: 1px solid rgba(229,9,20,0.2); display: flex; align-items: center; justify-content: center; overflow: hidden; }
  .team-visual-text { font-family: 'Bebas Neue', sans-serif; font-size: 8rem; color: rgba(229,9,20,0.08); position: absolute; letter-spacing: 10px; user-select: none; }
  .team-badge { width: 160px; height: 160px; background: radial-gradient(circle, rgba(229,9,20,0.2), rgba(229,9,20,0.02)); border: 2px solid rgba(229,9,20,0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 3rem; letter-spacing: 4px; color: var(--red); position: relative; z-index: 1; }

  .matches-section { margin-top: 48px; }
  .winloss-board { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 40px; }
  .wl-box { background: var(--dark2); border: 1px solid rgba(255,255,255,0.06); padding: 36px 24px; text-align: center; transition: transform 0.3s; }
  .wl-box:hover { transform: translateY(-4px); }
  .wl-box.wins { border-top: 3px solid #22c55e; }
  .wl-box.losses { border-top: 3px solid var(--red); }
  .wl-box.ratio { border-top: 3px solid #f59e0b; }
  .wl-number { font-family: 'Bebas Neue', sans-serif; font-size: 5rem; line-height: 1; margin-bottom: 8px; }
  .wl-box.wins .wl-number { color: #22c55e; }
  .wl-box.losses .wl-number { color: var(--red); }
  .wl-box.ratio .wl-number { color: #f59e0b; }
  .wl-bar { height: 6px; background: rgba(255,255,255,0.06); border-radius: 3px; margin-top: 24px; overflow: hidden; }
  .wl-bar-fill { height: 100%; background: linear-gradient(90deg, #22c55e, #16a34a); border-radius: 3px; transition: width 0.8s cubic-bezier(0.4,0,0.2,1); }

  .matches-list { display: flex; flex-direction: column; gap: 8px; }
  .match-row { display: grid; grid-template-columns: auto 1fr; align-items: center; gap: 16px; background: var(--dark2); border: 1px solid rgba(255,255,255,0.05); padding: 16px 20px; transition: border-color 0.3s; }
  .match-row:hover { border-color: rgba(229,9,20,0.2); }
  .match-badge { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; font-family: 'Bebas Neue', sans-serif; font-size: 1rem; letter-spacing: 1px; font-weight: 900; border-radius: 2px; }
  .match-badge.w { background: rgba(34,197,94,0.15); color: #22c55e; border: 1px solid rgba(34,197,94,0.3); }
  .match-badge.l { background: rgba(229,9,20,0.15); color: var(--red); border: 1px solid rgba(229,9,20,0.3); }
  .match-label { font-family: 'Rajdhani', sans-serif; font-weight: 600; font-size: 1rem; letter-spacing: 1px; text-transform: uppercase; color: var(--light-grey); }

  .page-hero { min-height: 55vh; display: flex; align-items: flex-end; padding: 120px 5% 80px; position: relative; overflow: hidden; }
  .page-hero-bg { position: absolute; inset: 0; }
  .page-hero-content { position: relative; z-index: 2; }

  .timeline { position: relative; padding-left: 40px; margin-top: 60px; }
  .timeline::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: linear-gradient(180deg, var(--red), transparent); }
  .timeline-item { margin-bottom: 48px; position: relative; }
  .timeline-item::before { content: ''; position: absolute; left: -47px; top: 6px; width: 14px; height: 14px; background: var(--red); border-radius: 50%; box-shadow: 0 0 16px var(--red-glow); }
  .timeline-date { font-family: 'Rajdhani', sans-serif; font-size: 0.8rem; letter-spacing: 3px; color: var(--red); text-transform: uppercase; margin-bottom: 8px; }
  .timeline-title { font-family: 'Rajdhani', sans-serif; font-size: 1.2rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; }
  .timeline-desc { color: var(--grey); font-size: 0.9rem; line-height: 1.7; }

  .highlights-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2px; margin-top: 60px; }
  .highlight-item { background: var(--dark2); padding: 40px; position: relative; overflow: hidden; transition: all 0.3s; }
  .highlight-item:hover { background: var(--dark3); }
  .highlight-num { font-family: 'Bebas Neue', sans-serif; font-size: 5rem; color: rgba(229,9,20,0.12); position: absolute; top: -10px; right: 20px; line-height: 1; user-select: none; }
  .highlight-title { font-family: 'Rajdhani', sans-serif; font-size: 1.2rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 12px; position: relative; z-index: 1; }
  .highlight-desc { color: var(--grey); font-size: 0.9rem; line-height: 1.7; position: relative; z-index: 1; }

  footer { background: var(--dark); border-top: 1px solid rgba(229,9,20,0.15); padding: 60px 5% 40px; }
  .footer-top { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; margin-bottom: 60px; }
  .footer-brand p { color: var(--grey); font-size: 0.9rem; line-height: 1.8; margin-top: 16px; max-width: 280px; }
  .footer-col h4 { font-family: 'Rajdhani', sans-serif; font-weight: 700; letter-spacing: 3px; font-size: 0.85rem; text-transform: uppercase; color: var(--red); margin-bottom: 20px; }
  .footer-col ul { list-style: none; }
  .footer-col ul li { margin-bottom: 10px; }
  .footer-col ul li a { color: var(--grey); text-decoration: none; font-size: 0.9rem; transition: color 0.3s; cursor: pointer; }
  .footer-col ul li a:hover { color: var(--white); }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.06); padding-top: 30px; display: flex; justify-content: space-between; align-items: center; }
  .footer-bottom p { color: var(--grey); font-size: 0.8rem; letter-spacing: 1px; }

  @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
  .reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.7s, transform 0.7s; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ADMIN */
  #admin-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 10000; backdrop-filter: blur(10px); align-items: center; justify-content: center; }
  #admin-overlay.open { display: flex; }
  #admin-login, #admin-panel { background: var(--dark2); border: 1px solid rgba(229,9,20,0.3); padding: 48px; width: 100%; position: relative; }
  #admin-login { max-width: 440px; }
  #admin-panel { max-width: 700px; max-height: 90vh; overflow-y: auto; }
  .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 36px; }
  .admin-title { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; letter-spacing: 4px; color: var(--red); }
  .admin-close { background: none; border: 1px solid rgba(255,255,255,0.2); color: var(--grey); width: 36px; height: 36px; cursor: pointer; font-size: 1.2rem; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
  .admin-close:hover { border-color: var(--red); color: var(--red); }
  .form-group { margin-bottom: 24px; }
  .form-group label { display: block; font-family: 'Rajdhani', sans-serif; font-size: 0.8rem; letter-spacing: 3px; text-transform: uppercase; color: var(--grey); margin-bottom: 8px; }
  .form-group input, .form-group textarea, .form-group select { width: 100%; background: var(--dark); border: 1px solid rgba(255,255,255,0.1); color: var(--white); padding: 12px 16px; font-family: 'Exo 2', sans-serif; font-size: 0.95rem; outline: none; transition: border-color 0.3s; resize: vertical; }
  .form-group input:focus, .form-group textarea:focus { border-color: var(--red); }
  .form-error { color: var(--red); font-size: 0.85rem; margin-top: 12px; display: none; }
  .admin-tabs { display: flex; gap: 4px; margin-bottom: 36px; border-bottom: 1px solid rgba(255,255,255,0.08); flex-wrap: wrap; }
  .admin-tab { background: none; border: none; color: var(--grey); font-family: 'Rajdhani', sans-serif; font-size: 0.85rem; letter-spacing: 2px; text-transform: uppercase; padding: 10px 20px; cursor: pointer; border-bottom: 2px solid transparent; margin-bottom: -1px; transition: all 0.3s; }
  .admin-tab.active { color: var(--red); border-bottom-color: var(--red); }
  .admin-tab:hover { color: var(--white); }
  .admin-section { display: none; }
  .admin-section.active { display: block; }
  .player-list { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
  .player-item { display: flex; align-items: center; gap: 12px; background: var(--dark); padding: 12px 16px; border: 1px solid rgba(255,255,255,0.06); }
  .player-item span { flex: 1; font-family: 'Rajdhani', sans-serif; font-size: 0.95rem; }
  .role-tag { font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase; padding: 3px 8px; }
  .del-btn { background: none; border: 1px solid rgba(229,9,20,0.3); color: var(--red); cursor: pointer; padding: 4px 10px; font-size: 0.8rem; transition: all 0.3s; }
  .del-btn:hover { background: rgba(229,9,20,0.15); }

  /* W/L BUTTONS */
  .wl-btn-group { display: flex; gap: 10px; }
  .wl-btn { flex: 1; padding: 14px; font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; letter-spacing: 4px; border: 2px solid rgba(255,255,255,0.1); background: transparent; color: var(--grey); cursor: pointer; transition: all 0.2s; }
  .wl-btn.win { border-color: rgba(34,197,94,0.3); color: rgba(34,197,94,0.5); }
  .wl-btn.win.selected, .wl-btn.win:hover { background: rgba(34,197,94,0.15); border-color: #22c55e; color: #22c55e; }
  .wl-btn.loss { border-color: rgba(229,9,20,0.3); color: rgba(229,9,20,0.5); }
  .wl-btn.loss.selected, .wl-btn.loss:hover { background: rgba(229,9,20,0.15); border-color: var(--red); color: var(--red); }

  .save-indicator { position: fixed; bottom: 30px; right: 30px; background: var(--red); color: white; padding: 12px 24px; font-family: 'Rajdhani', sans-serif; font-size: 0.9rem; letter-spacing: 2px; text-transform: uppercase; z-index: 99999; transform: translateY(80px); transition: transform 0.4s; pointer-events: none; }
  .save-indicator.show { transform: translateY(0); }

  /* HERO SOCIAL BUTTONS */
  .hero-social { margin-top: 40px; text-align: center; }
  .hero-social-label { font-family: 'Rajdhani', sans-serif; font-size: 0.75rem; letter-spacing: 5px; color: var(--grey); text-transform: uppercase; margin-bottom: 16px; }
  .hero-social-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .hero-social-btn { display: flex; align-items: center; gap: 12px; padding: 16px 28px; text-decoration: none; color: var(--white); border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); backdrop-filter: blur(10px); transition: all 0.3s; position: relative; overflow: hidden; clip-path: polygon(0 0, calc(100% - 10px) 0, 100% 10px, 100% 100%, 10px 100%, 0 calc(100% - 10px)); }
  .hero-social-btn::before { content: ''; position: absolute; inset: 0; opacity: 0; transition: opacity 0.3s; }
  .discord-hero-btn::before { background: rgba(88,101,242,0.15); }
  .tiktok-hero-btn::before { background: rgba(229,9,20,0.12); }
  .hero-social-btn:hover::before { opacity: 1; }
  .discord-hero-btn { border-color: rgba(88,101,242,0.35); }
  .discord-hero-btn:hover { border-color: #5865f2; box-shadow: 0 0 30px rgba(88,101,242,0.3), 0 8px 32px rgba(0,0,0,0.4); transform: translateY(-3px); }
  .discord-hero-btn svg { color: #5865f2; position: relative; z-index: 1; }
  .tiktok-hero-btn { border-color: rgba(229,9,20,0.35); }
  .tiktok-hero-btn:hover { border-color: var(--red); box-shadow: 0 0 30px var(--red-glow), 0 8px 32px rgba(0,0,0,0.4); transform: translateY(-3px); }
  .tiktok-hero-btn svg { color: var(--red); position: relative; z-index: 1; }
  .hero-social-btn span:first-of-type { font-family: 'Rajdhani', sans-serif; font-size: 1.1rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; position: relative; z-index: 1; }
  .hero-social-handle { font-family: 'Rajdhani', sans-serif; font-size: 0.8rem; letter-spacing: 1px; color: var(--grey); position: relative; z-index: 1; border-left: 1px solid rgba(255,255,255,0.15); padding-left: 12px; }

  /* SOCIAL BIG BUTTONS */
  .social-big-btns { display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; max-width: 900px; margin: 0 auto; }
